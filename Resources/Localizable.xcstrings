    "jotConflict.subtitle" : {
      "comment" : "Subtitle explaining the conflict; %@ is the name of the jot",
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” is op twee toestelle gelyktydig gewysig. Kies ’n weergawe om te hou."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«%@» تم تحريره على جهازين في الوقت نفسه. اختر النسخة التي تريد الاحتفاظ بها."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" wurde auf zwei Geräten gleichzeitig bearbeitet. Wähle eine Version zum Behalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" was edited on two devices at the same time. Choose a version to keep."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«%@» fue editado en dos dispositivos a la vez. Elige qué versión conservar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« %@ » a été modifié sur deux appareils en même temps. Choisissez la version à conserver."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” को एक साथ दो डिवाइस पर संपादित किया गया। रखने के लिए एक वर्शन चुनें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” diedit di dua perangkat secara bersamaan. Pilih versi yang ingin disimpan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«%@» è stato modificato su due dispositivi contemporaneamente. Scegli quale versione mantenere."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」が2台のデバイスで同時に編集されました。保持するバージョンを選んでください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@”이(가) 두 기기에서 동시에 편집되었습니다. 유지할 버전을 선택하세요."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” telah diedit pada dua peranti secara serentak. Pilih versi yang ingin disimpan."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” is op twee apparaten tegelijk bewerkt. Kies welke versie je wilt bewaren."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„%@” został edytowany na dwóch urządzeniach jednocześnie. Wybierz wersję do zachowania."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” foi editado em dois dispositivos ao mesmo tempo. Escolha qual versão manter."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«%@» foi editado em dois dispositivos ao mesmo tempo. Escolhe uma versão para manter."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«%@» был изменён на двух устройствах одновременно. Выберите версию для сохранения."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” redigerades på två enheter samtidigt. Välj vilken version du vill behålla."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” ถูกแก้ไขบนสองอุปกรณ์พร้อมกัน เลือกเวอร์ชันที่ต้องการเก็บ"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” iki cihazda aynı anda düzenlendi. Saklamak istediğiniz sürümü seçin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«%@» було відредаговано на двох пристроях одночасно. Оберіть версію для збереження."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” đã được chỉnh sửa trên hai thiết bị cùng lúc. Chọn phiên bản cần giữ."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」在两台设备上被同时编辑。请选择要保留的版本。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「%@」在兩部裝置上被同時編輯。請選擇要保留的版本。"
          }
        }
      }
    },
