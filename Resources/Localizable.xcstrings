    "cloudMigration.subtitle": {
      "comment": "Subtitle on the iCloud migration screen",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Jots können jetzt geräteübergreifend synchronisiert werden. Wähle aus, welche du übernehmen möchtest."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your Jots can now sync across all your devices. Choose which ones to bring along."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके Jots अब आपके सभी डिवाइस पर सिंक हो सकते हैं। चुनें कि कौन से साथ लाने हैं।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的 Jots 现在可以在所有设备间同步。选择要保留的内容。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的 Jots 現在可以在所有裝置間同步。選擇要保留的項目。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Jots をすべてのデバイス間で同期できるようになりました。引き継ぐものを選んでください。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus Jots ahora pueden sincronizarse en todos tus dispositivos. Elige cuáles conservar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Os teus Jots podem agora sincronizar-se em todos os teus dispositivos. Escolhe quais trazer."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seus Jots agora podem sincronizar em todos os seus dispositivos. Escolha quais manter."
          }
        },
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Jou Jots kan nou op al jou toestelle sinkroniseer. Kies watter om saam te bring."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Тепер ваші Jots можуть синхронізуватися між усіма пристроями. Оберіть, які залишити."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمكن الآن مزامنة Jots عبر جميع أجهزتك. اختر ما تريد الاحتفاظ به."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이제 Jots를 모든 기기에서 동기화할 수 있습니다. 가져올 항목을 선택하세요."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Jots ของคุณสามารถซิงค์ข้ามอุปกรณ์ได้แล้ว เลือกรายการที่ต้องการนำติดไปด้วย"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Jots của bạn giờ có thể đồng bộ trên mọi thiết bị. Chọn mục muốn giữ lại."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Jots Anda kini bisa disinkronkan di semua perangkat. Pilih yang ingin dibawa."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Jots anda kini boleh disegerakkan merentasi semua peranti. Pilih yang ingin dibawa bersama."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos Jots peuvent maintenant se synchroniser sur tous vos appareils. Choisissez lesquels conserver."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I tuoi Jots ora possono essere sincronizzati su tutti i tuoi dispositivi. Scegli quali mantenere."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je Jots kunnen nu worden gesynchroniseerd op al je apparaten. Kies welke je wilt meenemen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twoje Jots mogą teraz synchronizować się na wszystkich urządzeniach. Wybierz, które chcesz zachować."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Jots'larınız artık tüm cihazlarınızda eşitlenebilir. Hangilerini taşımak istediğinizi seçin."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваши Jots теперь могут синхронизироваться на всех устройствах. Выберите, какие перенести."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dina Jots kan nu synkas mellan alla dina enheter. Välj vilka du vill ta med."
          }
        }
      }
    },
