    "notes.delete.message": {
      "comment": "Confirmation message in the Delete Note alert",
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Möchtest du diese Notiz wirklich löschen? Diese Aktion kann nicht rückgängig gemacht werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to delete this note? This action cannot be undone."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "क्या आप वाकई यह नोट हटाना चाहते हैं? यह क्रिया पूर्ववत नहीं की जा सकती।"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要删除这条笔记吗？此操作无法撤销。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要刪除這則筆記嗎？此操作無法復原。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このノートを削除しますか？この操作は取り消せません。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Seguro que quieres eliminar esta nota? Esta acción no se puede deshacer."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Tens a certeza de que queres eliminar esta nota? Esta ação não pode ser revertida."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja apagar esta nota? Esta ação não pode ser desfeita."
          }
        },
        "af": {
          "stringUnit": {
            "state": "translated",
            "value": "Is jy seker jy wil hierdie nota verwyder? Hierdie aksie kan nie ongedaan gemaak word nie."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви впевнені, що хочете видалити цю нотатку? Цю дію не можна скасувати."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل أنت متأكد من حذف هذه الملاحظة؟ لا يمكن التراجع عن هذا الإجراء."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 노트를 삭제하시겠습니까? 이 작업은 되돌릴 수 없습니다."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คุณแน่ใจหรือไม่ว่าต้องการลบโน้ตนี้? การดำเนินการนี้ไม่สามารถย้อนกลับได้"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn có chắc muốn xóa ghi chú này không? Hành động này không thể hoàn tác."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Yakin ingin menghapus catatan ini? Tindakan ini tidak dapat dibatalkan."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Adakah anda pasti mahu memadam nota ini? Tindakan ini tidak boleh dibuat asal."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous vraiment supprimer cette note ? Cette action est irréversible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei sicuro di voler eliminare questa nota? Questa azione non può essere annullata."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Weet je zeker dat je deze notitie wilt verwijderen? Deze actie kan niet ongedaan worden gemaakt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Czy na pewno chcesz usunąć tę notatkę? Tej czynności nie można cofnąć."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu notu silmek istediğinizden emin misiniz? Bu işlem geri alınamaz."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы уверены, что хотите удалить эту заметку? Это действие нельзя отменить."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Är du säker på att du vill radera den här anteckningen? Åtgärden kan inte ångras."
          }
        }
      }
    },
