    "cloudMigration.subtitle" : {
      "comment" : "Subtitle on the iCloud migration screen",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Jots können jetzt geräteübergreifend synchronisiert werden. Wähle aus, welche du übernehmen möchtest."
